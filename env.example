# .env.example — Project David / Entities Platform
#
# HOW TO USE:
#   Option A (recommended): Run the orchestrator — it auto-generates all secrets
#   and walks you through optional values interactively:
#
#     pip install projectdavid-platform
#     entities-dev --mode up
#
#   Option B (manual): Copy this file to .env and replace every __PLACEHOLDER__
#   with a real value before starting the stack.
#
#     cp .env.example .env
#
# UPDATING OPTIONAL VALUES AFTER SETUP:
#   entities-dev configure --set HF_TOKEN=hf_abc123
#   entities-dev configure --interactive
#
# PLACEHOLDERS:
#   __GENERATED__     Auto-generated by the orchestrator. Never set manually.
#                     Delete .env and re-run entities-dev to regenerate.
#   __USER_SUPPLIED__ Must be provided by you. Stack starts without them but
#                     related features will be unavailable until set.
#   __OPTIONAL__      Leave blank if not using this service or feature.

#############################
# Base URLs
#############################
ASSISTANTS_BASE_URL=http://localhost:9000
SANDBOX_SERVER_URL=http://sandbox:8000
DOWNLOAD_BASE_URL=http://localhost:9000/v1/files/download

#############################
# AI Model Configuration
#############################
# Your HuggingFace personal access token.
# Required only for downloading gated models via vLLM.
# Get one at: https://huggingface.co/settings/tokens
# Stack starts fine without this — press Enter to skip during setup, or set later:
#   entities-dev configure --set HF_TOKEN=hf_abc123
HF_TOKEN=__USER_SUPPLIED__

# Local path where HuggingFace model weights are cached.
# Auto-resolved to ~/.cache/huggingface by the orchestrator if left blank.
HF_CACHE_PATH=__USER_SUPPLIED__

# The vLLM model to load on startup (GPU stack only).
# Override to switch models: entities-dev configure --set VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct

#############################
# Database Configuration
#############################
# Both DATABASE_URL and SPECIAL_DB_URL are auto-constructed by the orchestrator.
DATABASE_URL=mysql+pymysql://api_user:__GENERATED__@db:3306/entities_db
SPECIAL_DB_URL=mysql+pymysql://api_user:__GENERATED__@localhost:3307/entities_db

# !! Auto-generated — never set a weak password manually !!
MYSQL_ROOT_PASSWORD=__GENERATED__
MYSQL_DATABASE=entities_db
MYSQL_USER=api_user
# !! Auto-generated — never set a weak password manually !!
MYSQL_PASSWORD=__GENERATED__
MYSQL_HOST=db
MYSQL_PORT=3306
REDIS_URL=redis://redis:6379/0

#############################
# API Keys & Secrets
#############################
# All auto-generated by the orchestrator on first run.
API_KEY=__GENERATED__
ADMIN_API_KEY=__GENERATED__
SIGNED_URL_SECRET=__GENERATED__
SANDBOX_AUTH_SECRET=__GENERATED__
SECRET_KEY=__GENERATED__
DEFAULT_SECRET_KEY=__GENERATED__
SEARXNG_SECRET_KEY=__GENERATED__

#############################
# Platform Settings
#############################
BASE_URL_HEALTH=http://localhost:9000/v1/health
SHELL_SERVER_URL=ws://sandbox:8000/ws/computer
SHELL_SERVER_EXTERNAL_URL=ws://localhost:8000/ws/computer
CODE_EXECUTION_URL=ws://sandbox:8000/ws/execute
DISABLE_FIREJAIL=true
SHARED_PATH=./shared_data
AUTO_MIGRATE=1

#############################
# Admin Configuration
#############################
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_ID=__OPTIONAL__
ADMIN_KEY_PREFIX=__OPTIONAL__

#############################
# SMB Client Configuration
#############################
SMBCLIENT_SERVER=samba_server
SMBCLIENT_SHARE=cosmic_share
SMBCLIENT_USERNAME=samba_user
# !! Auto-generated — never set manually !!
SMBCLIENT_PASSWORD=__GENERATED__
SMBCLIENT_PORT=445

#############################
# Samba Server Configuration
#############################
SAMBA_USERID=1000
SAMBA_GROUPID=1000

#############################
# Tool Identifiers
#############################
# Auto-generated. Replace only if you need stable IDs across reinstalls.
TOOL_CODE_INTERPRETER=tool___GENERATED__
TOOL_WEB_SEARCH=tool___GENERATED__
TOOL_COMPUTER=tool___GENERATED__
TOOL_VECTOR_STORE_SEARCH=tool___GENERATED__

#############################
# Other
#############################
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
